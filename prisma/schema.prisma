generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model SystemConfig {
  id            String   @id @default("default")
  scrapingUrls  String[]
  footballApiKey String?
  geminiApiKey  String?
  geminiEnabled Boolean  @default(true)
  grokApiKey    String?
  grokEnabled   Boolean  @default(false)
  mistralApiKey String?
  mistralEnabled Boolean @default(false)
  analystPrompt String   @db.Text
  scraperPrompt String   @db.Text
  updatedAt     DateTime @updatedAt
}

model PredictionSlip {
  id          String   @id @default(cuid())
  totalOdds   Float
  confidence  Int
  targetOdds  Int
  matches     Json     // Store the list of matches in the slip
  createdAt   DateTime @default(now())
}
