generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model SystemConfig {
  id              String   @id @default("default")
  scrapingUrls    String[]
  
  footballApiKey1 String?
  footballApi1Enabled Boolean @default(true)
  footballApiKey2 String?
  footballApi2Enabled Boolean @default(false)
  footballApiKey3 String?
  footballApi3Enabled Boolean @default(false)
  footballApiKey4 String?
  footballApi4Enabled Boolean @default(false)

  geminiApiKey  String?
  geminiEnabled Boolean  @default(true)
  geminiModel   String   @default("gemini-1.5-flash")
  grokApiKey    String?
  grokEnabled   Boolean  @default(false)
  mistralApiKey String?
  mistralEnabled Boolean @default(false)
  analystPrompt String   @db.Text
  scraperPrompt String   @db.Text
  processorPrompt String @default("You are an expert data processor. Your job is to take raw match data and organize it into a clean, structured format for analysis. Sort matches by league and time, and ensure all stats are normalized.") @db.Text
  aiAnalysisEnabled Boolean @default(true)
  predictionThreshold Int @default(75)
  updatedAt     DateTime @updatedAt
}

model ProcessedData {
  id          String   @id @default(cuid())
  matchDate   DateTime?
  homeTeam    String
  awayTeam    String
  league      String
  summary     String   @db.Text
  structuredData Json
  createdAt   DateTime @default(now())
}

model PredictionSlip {
  id          String   @id @default(cuid())
  totalOdds   Float
  confidence  Int
  targetOdds  Int
  matches     Json     // Store the list of matches in the slip
  status      String   @default("PENDING") // PENDING, WON, LOST
  actualResults Json?  // Store actual scores for learning
  createdAt   DateTime @default(now())
}

model ScrapedData {
  id          String   @id @default(cuid())
  sourceApi   String
  matchId     String?  // External ID if available
  homeTeam    String
  awayTeam    String
  league      String
  matchDate   DateTime?
  odds        Json     // Home, draw, away odds
  rawStats    Json?    // Raw API data
  createdAt   DateTime @default(now())
}
